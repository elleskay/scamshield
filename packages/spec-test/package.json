{
  "name": "@platform/spec-test",
  "version": "0.1.0",
  "private": true,
  "description": "Spec-driven test runner. Validates spec YAML, registers specTest IDs, enforces 100% coverage in CI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.ts",
      "import": "./dist/playwright.js",
      "require": "./dist/cjs/playwright.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "import": "./dist/vitest.js",
      "require": "./dist/cjs/vitest.js"
    },
    "./jest": {
      "types": "./dist/jest.d.ts",
      "import": "./dist/jest.js",
      "require": "./dist/cjs/jest.js"
    },
    "./detox": {
      "types": "./dist/detox.d.ts",
      "import": "./dist/detox.js",
      "require": "./dist/cjs/detox.js"
    },
    "./maestro": {
      "types": "./dist/maestro.d.ts",
      "import": "./dist/maestro.js",
      "require": "./dist/cjs/maestro.js"
    }
  },
  "bin": {
    "spec-coverage": "./dist/cli.js",
    "spec-attest": "./dist/attest.js",
    "spec-maestro": "./dist/maestro.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "yaml": "^2.5.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@playwright/test": "^1.48.0",
    "vitest": "^4.1.7"
  },
  "peerDependenciesMeta": {
    "@playwright/test": { "optional": true },
    "vitest": { "optional": true }
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/eslint": "^9.0.0",
    "@types/estree": "^1.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
