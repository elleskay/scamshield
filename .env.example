# Platform-level env vars only. App- and service-specific keys live in each
# app/service's own .env.example.

# AWS (for CDK deploy)
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=

# CI / GitHub
GITHUB_TOKEN=

# Expo / EAS (mobile app build + submit + OTA update)
EXPO_TOKEN=
EAS_PROJECT_ID=

# --- API runtime env vars (NestJS service, set per environment) ---
# Helpers no-op cleanly when their env vars aren't set. Set them in GitHub
# Actions secrets and Lambda env vars for production. Local dev is fine without.

# Database (Postgres; Neon serverless is the default for connection pooling)
DATABASE_URL=

# Auth (JWT signing for API tokens issued to the mobile client)
JWT_SECRET=
JWT_ISSUER=mobile-platform

# Report intake queue (AWS SQS). Set by CDK output after deploy.
REPORTS_QUEUE_URL=

# OpenSearch (scam-message clustering; optional, off by default)
OPENSEARCH_ENDPOINT=

# Push notifications
# iOS: APNs key (.p8), team + key ids. Android: FCM service-account JSON path.
APNS_KEY_ID=
APNS_TEAM_ID=
FCM_SERVICE_ACCOUNT_JSON=
EXPO_ACCESS_TOKEN=

# LLM classifier (phishing-link / scam-message detection hook)
CLASSIFIER_API_URL=
CLASSIFIER_API_KEY=

# Observability (DataDog)
DD_API_KEY=
DD_SITE=ap1.datadoghq.com
DD_SERVICE=mobile-platform-api
