# NestJS API service env. Copy to .env.local for dev. Production values live in
# Lambda env vars / AWS Secrets Manager, never committed.

PORT=3000

# Postgres (Neon serverless for connection pooling on Lambda)
DATABASE_URL=

# JWT signing for tokens issued to the mobile client
JWT_SECRET=
JWT_ISSUER=mobile-platform

# Report intake queue (SQS). Set from the CDK output after deploy. Unset locally
# makes the service process reports inline instead of enqueuing.
REPORTS_QUEUE_URL=

# OpenSearch for clustering similar reports. Unset => indexing no-ops.
OPENSEARCH_ENDPOINT=

# LLM classifier. Unset => deterministic heuristic fallback.
CLASSIFIER_API_URL=
CLASSIFIER_API_KEY=

# Observability
DD_SERVICE=mobile-platform-api
DD_API_KEY=
